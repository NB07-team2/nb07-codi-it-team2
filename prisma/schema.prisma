// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  BUYER
  SELLER
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  type          UserType
  points        Int      @default(0)
  totalPurchase Int      @default(0) //누적 금액( 등급 산정 기준)
  image         String   @default("https://codi-it-s3.s3.amazonaws.com/others/b7220551-54e3-414f-bed1-801a44e71d45.png")

  gradeId String @default("grade_green")
  grade   Grade  @relation(fields: [gradeId], references: [id])

  myStore        Store?     @relation("UserStore") //판매자의 경우 1:1
  favoriteStores Favorite[] //구매자의 경우 내가 추가한 관심 스토어들 (N:N)
  inquiries      Inquiry[] // 내가 작성한 상품 문의들 
  reviews        Review[] // 내가 작성한 리뷰들

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  cart          Cart?
  notifications Notification[]
  orders        Order[]
  replies       Reply[] // 이 유저가 작성한 답변들

  @@map("user")
}

model Store {
  id            String  @id @default(cuid())
  name          String
  address       String
  detailAddress String
  phoneNumber   String  @unique
  content       String  @db.Text
  image         String?

  userId String @unique //1:1 관계
  user   User   @relation("UserStore", fields: [userId], references: [id], onDelete: Cascade)

  favoritedBy Favorite[] // 이 스토어를 관심 등록한 유저들
  products    Product[] // 스토어의 상품들
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("store")
}

model Grade {
  id        String @id
  name      String @unique
  rate      Int //할인 율
  minAmount Int //달성 최소 금액

  users User[]

  @@map("grade")
}

// 관심 스토어 중간 테이블
model Favorite {
  id      Int    @id @default(autoincrement())
  userId  String
  storeId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, storeId]) // 한 유저가 관심스토어 중복 방지
  @@map("favorite")
}

enum InquiryStatus {
  WaitingAnswer
  CompletedAnswer
}

model Inquiry {
  id        String        @id @default(cuid())
  userId    String
  productId String
  title     String
  content   String        @db.Text
  status    InquiryStatus @default(WaitingAnswer)
  isSecret  Boolean       @default(false)
  user      User          @relation(fields: [userId], references: [id])
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  reply     Reply? // 1:1 관계, 답변이 없는 경우 null 허용
  product   Product       @relation(fields: [productId], references: [id])

  @@index([productId])
  @@index([userId])
  @@map("inquiry")
}

model Reply {
  id        String   @id @default(cuid())
  userId    String
  inquiryId String   @unique
  content   String   @db.Text
  inquiry   Inquiry  @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reply")
}

model Cart {
  id      String     @id @default(cuid())
  buyerId String     @unique // 한 구매자는 하나의 장바구니만 가짐
  user    User       @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  items   CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cart")
}

model CartItem {
  id     String @id @default(cuid())
  cartId String
  cart   Cart   @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  sizeId Int
  size   Size @relation(fields: [sizeId], references: [id])

  stockId String
  stock   Stock  @relation(fields: [stockId], references: [id])

  quantity Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cart_item")
}

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  content   String
  isChecked Boolean          @default(false) // 명세서의 isChecked 반영
  type      NotificationType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notification")
}

enum NotificationType {
  SOLDOUT //품절 알림
  NEW_INQUIRY // 새문의
  INQUIRY_ANSWER // 답변 등록
}

model Order {
  id            String   @id @default(cuid())
  name          String // 주문자 이름
  phone         String // 주문자 연락처
  address       String // 주문자 주소
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtotal      Int // 상품 가격 * 수량의 합계
  totalQuantity Int // 주문한 총 수량
  usePoint      Int // 사용한 포인트
  totalSales    Int // 해당 주문의 총 매출액
  createdAt     DateTime @default(now())

  orderItems OrderItem[]
  payments   Payment?

  @@map("order")
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  price      Int // 판매가
  quantity   Int // 판매 수량
  name       String // 주문 당시 상품명(할인 적용 여부 등 변동 가능성 고려)
  review     Review? // 1:1 관계, 리뷰가 없는 경우 null 허용
  isReviewed Boolean @default(false) // 리뷰 작성 여부
  sizeId     Int
  size       Size    @relation(fields: [sizeId], references: [id])

  @@map("order_item")
}

model Product {
  id      String  @id @default(cuid())
  name    String
  image   String?
  content String? @db.Text

  price     Int
  isSoldOut Boolean @default(false)
  sales     Int     @default(0)

  // 할인
  discountRate      Int?
  discountStartTime DateTime?
  discountEndTime   DateTime?

  storeId String
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  categoryId String
  category   ProductCategory @relation(fields: [categoryId], references: [id])

  reviews   Review[]
  stocks    Stock[]
  inquiries Inquiry[]
  cartItems CartItem[]

  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([storeId])
  @@index([categoryId])
  @@map("product")
}

enum ProductCategoryName {
  all
  top
  bottom
  dress
  outer
  skirt
  shoes
  acc
}

model ProductCategory {
  id   String              @id @default(cuid())
  name ProductCategoryName @unique

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("category")
}

model Size {
  id         Int         @id @default(autoincrement())
  name       String // 예: "S", "M", "L" 등
  enName     String? // LARGE, MEDIUM, SMALL 등 영문 사이즈명
  koName     String? // 라지, 미디엄, 스몰 등 한글 사이즈명
  stocks     Stock[]
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([name]) // 같은 사이즈명 중복 방지(선택)
}

// 사이즈별 재고
model Stock {
  id       String @id @default(cuid())
  size     Size   @relation(fields: [sizeId], references: [id])
  quantity Int    @default(0)
  sizeId   Int

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartItems CartItem[]

  @@unique([productId, sizeId]) // 상품 사이즈 중복 방지
  @@index([productId])
  @@index([sizeId])
  @@map("stock")
}

model Review {
  id      String @id @default(cuid())
  rating  Int
  content String @db.Text

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  orderItemId String    @unique
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([productId])
  @@index([orderItemId])
  @@map("review")
}

enum PaymentStatus {
  WaitingPayment
  CompletedPayment
}

model Payment {
  id        String        @id @default(cuid())
  orderId   String        @unique
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  price     Int
  status    PaymentStatus @default(WaitingPayment)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("payment")
}
