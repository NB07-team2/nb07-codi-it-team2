// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  BUYER
  SELLER
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  type          UserType
  point         Int      @default(0)
  totalPurchase Int      @default(0) //누적 금액( 등급 산정 기준)

  image String @default("http://추후에 기본이미지 링크로 수정")

  gradeId String @default("grade_green")
  grade   Grade  @relation(fields: [gradeId], references: [id])

  myStore        Store?     @relation("UserStore") //판매자의 경우 1:1
  favoriteStores Favorite[] //구맺자의 경우 내가 추가한 관심 스토어들 (N:N)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users") // 실제 DB 테이블 이름은 소문자 users로 생성
}

model Store {
  id            String  @id @default(cuid())
  name          String
  address       String
  detailAddress String
  phoneNumber   String
  content       String  @db.Text
  image         String?

  userId String @unique //1:1 관계
  user   User   @relation("UserStore", fields: [userId], references: [id], onDelete: Cascade)

  favoritedBy Favorite[] // 이 스토어를 관심 등록한 유저들

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stores")
}

model Grade {
  id        String @id
  name      String @unique
  rate      Int
  minAmount Int

  users User[]

  @@map("grades")
}

// 관심 스토어 중간 테이블
model Favorite {
  id      Int    @id @default(autoincrement())
  userId  String
  storeId String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, storeId]) // 한 유저가 같은 스토어를 중복 찜 방지
  @@map("favorites")
}
