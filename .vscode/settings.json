{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.formatOnSave": true,
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[prisma]": {
    "editor.defaultFormatter": "prisma.prisma"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#faeaee",
    "activityBar.background": "#faeaee",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#4db42b",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#15202b99",
    "sash.hoverBorder": "#faeaee",
    "statusBar.background": "#f0c1ce",
    "statusBar.foreground": "#15202b",
    "statusBarItem.hoverBackground": "#e698ae",
    "statusBarItem.remoteBackground": "#f0c1ce",
    "statusBarItem.remoteForeground": "#15202b",
    "titleBar.activeBackground": "#f0c1ce",
    "titleBar.activeForeground": "#15202b",
    "titleBar.inactiveBackground": "#f0c1ce99",
    "titleBar.inactiveForeground": "#15202b99"
  },
  "peacock.color": "#f0c1ce"
}
